{
  "manifest_version": 3,
  "name": "TP DM Assist",
  "version": "1.0",
  "description": "AI reply suggestions for Instagram DMs",
  "permissions": ["storage"],
  "host_permissions": [
    "https://www.instagram.com/*",
    "http://localhost:3001/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://www.instagram.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
