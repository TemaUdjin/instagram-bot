# ─── Instagram ───────────────────────────────────────────────────────────────
# Type: IGAA long-lived token (starts with "IGAA")
# Get from: Meta App Dashboard → Instagram → Generate Token
# Expires: ~60 days. Check /debug-token to verify.
PAGE_ACCESS_TOKEN=IGAAxxxxxxxxx...

# Your Instagram Business Account ID (17+ digit number)
# Confirm at: /debug-token → account.id
BUSINESS_ACCOUNT_ID=17841400228014487

# Your Facebook Page ID linked to the Instagram account
PAGE_ID=279920309492026

# A secret string you choose — must match what is set in Meta webhook config
VERIFY_TOKEN=my_secret_token_123

# ─── Telegram ────────────────────────────────────────────────────────────────
# From @BotFather on Telegram
TELEGRAM_TOKEN=8660495826:AAE...

# Your personal Telegram chat ID — message @userinfobot to find it
CHAT_ID=784663861

# ─── Anthropic ───────────────────────────────────────────────────────────────
# From console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-api03-...
