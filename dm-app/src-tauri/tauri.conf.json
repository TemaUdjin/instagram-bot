{
  "productName": "Toward Perfection DM",
  "version": "0.1.0",
  "identifier": "com.towardperfection.dm",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev:all",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Toward Perfection DM",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "decorations": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "app",
    "icon": ["icons/icon.png"]
  },
  "plugins": {
    "opener": {}
  }
}
